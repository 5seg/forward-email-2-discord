{
  "$schema": "./node_modules/wrangler/config-schema.json",
  // Top-level configuration
  "name": "forward-email-2-discord",
  "main": "src/index.ts",
  "compatibility_date": "2026-02-13",
  "compatibility_flags": ["nodejs_compat_v2"],
  "send_metrics": false,
  "vars": {
    "WEBHOOK_URL": "",
  },
  "observability": {
    "logs": {
      "enabled": true,
      "invocation_logs": true,
    },
  },
}
